
DB_URL=postgresql://<USER>:<PASSWORD>@<HOST>:5432/postgres
# Connection used by the TypeORM migration CLI (migration:run runs on every
# `pnpm start:prod`). Point this at Supabase's DIRECT connection (port 5432),
# NOT the 6543 transaction pooler — DDL and advisory locks are unreliable under
# transaction pooling. Falls back to DB_URL when unset.
DB_MIGRATION_URL=postgresql://<USER>:<PASSWORD>@<HOST>:5432/postgres
VALHALLA_URL=http://localhost:8002
VROOM_URL=http://localhost:3000
PHOTON_URL=http://localhost:2322
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxx

CORS_DOMAIN=http://localhost:3000,https://hikyaku.org

STRIPE_API_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxx
# Stripe Issuing webhook signing secret (from `stripe listen` or the Dashboard
# endpoint subscribed to issuing.* events). Required by the issuing webhook.
STRIPE_ISSUING_WEBHOOK_SECRET=whsec_xxxxxx


MAILER_SENDER_EMAIL=auth@hikyaku.org
MAILER_HOST=localhost
MAILER_USER=xxxx
MAILER_PASSWORD=xxxxxx


APP_URL=http://localhost:3000